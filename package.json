{
  "name": "devzone.solutions",
  "version": "1.0.0",
  "description": "DevZone Solutions Website",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "watch:sass": "sass --no-source-map --pkg-importer=node --watch sass:assets/css",
    "watch:hugo": "hugo server -D --disableFastRender",
    "build:sass": "sass --no-source-map --pkg-importer=node sass:assets/css",
    "build:hugo": "hugo --minify",
    "start": "npm-run-all build:sass --parallel watch:*",
    "build": "npm-run-all build:sass build:hugo"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DiveZoneCompany/devzone.solutions.git"
  },
  "author": "DevZone Solutions",
  "bugs": {
    "url": "https://github.com/DiveZoneCompany/devzone.solutions/issues"
  },
  "homepage": "https://devzone.solutions/",
  "devDependencies": {
    "@divezone/divezone-web-styles": "^1.3.5"
  }
}