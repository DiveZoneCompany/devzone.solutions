{
  "name": "devzone.solutions",
  "version": "1.0.0",
  "description": "DevZone Solutions Website",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "watch:sass": "sass --no-source-map --pkg-importer=node --watch assets/sass:static/css",
    "watch:hugo": "hugo server -D",
    "watch:postcss": "postcss static/css/style.css --no-map --dir static/css --watch",
    "build:sass": "sass --no-source-map --pkg-importer=node assets/sass:static/css",
    "build:hugo": "hugo --minify",
    "build:postcss": "postcss static/css/style.css -r --no-map",
    "start": "npm-run-all build:sass --parallel watch:*",
    "build": "npm-run-all build:sass build:postcss build:hugo"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DiveZoneCompany/devzone.solutions.git"
  },
  "author": "DevZone Solutions",
  "bugs": {
    "url": "https://github.com/DiveZoneCompany/devzone.solutions/issues"
  },
  "homepage": "https://devzone.solutions/",
  "devDependencies": {
    "@divezone/divezone-web-styles": "^1.3.2",
    "html-minifier-terser": "^7.2.0",
    "luxon": "^3.7.1",
    "minify-xml": "^4.5.2",
    "npm-run-all": "^4.1.5",
    "path": "^0.12.7",
    "postcss-cli": "^11.0.0",
    "prettier": "^3.6.2",
    "sass": "^1.81.0"
  }
}
