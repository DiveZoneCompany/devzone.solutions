{
  "name": "devzone.solutions",
  "version": "1.0.0",
  "description": "DevZone Solutions Website",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "watch:sass": "sass --no-source-map --pkg-importer=node --watch assets/sass:public/css",
    "watch:hugo": "hugo server -D",
    "watch:postcss": "postcss public/css/style.css --no-map --dir public/css --watch",
    "build:sass": "sass --no-source-map --pkg-importer=node assets/sass:public/css",
    "build:hugo": "hugo --minify",
    "build:postcss": "postcss public/css/style.css -r --no-map",
    "start": "npm-run-all build:sass --parallel watch:*",
    "build": "npm-run-all build:sass build:postcss build:hugo"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DiveZoneCompany/devzone.solutions.git"
  },
  "author": "DevZone Solutions",
  "bugs": {
    "url": "https://github.com/DiveZoneCompany/devzone.solutions/issues"
  },
  "homepage": "https://devzone.solutions/",
  "devDependencies": {
    "@divezone/divezone-web-styles": "^1.3.3"
  }
}