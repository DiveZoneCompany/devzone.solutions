---
layout: base
eleventyImport:
  collections: ["homeSorted"]
---

<div class="hero">
  {{ content }}
</div>

<div class="home--tiles">
{%- for item in collections.homeSorted -%}
  <a href="{{ item.data.page.url }}" class="home--tile-link">
  <div {% if item.data.draft %}draft{% endif %} class="home--tile home--tile--{{ item.data.page.fileSlug }}">
    <div class="home--tile-icon">
      <i class="{{ item.data.homeIcon }}"></i>
    </div>
    <div class="home--tile-content">
      <h3>{{ item.data.title }}</h3>
      {%- if item.data.description %}
        <p>{{ item.data.description }}</p>
      {%- endif %}
    </div>
  </div>
  </a>
{%- endfor -%}
</div>